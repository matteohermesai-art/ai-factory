# .env.example - AI Factory Configuration
# Copy to .env and customize

# ═══ Application ═══
APP_NAME=ai-factory
APP_ENV=development
LOG_LEVEL=info

# ═══ Database ═══
DATABASE_URL=postgresql+asyncpg://neon:neon@db:5432/neoncity

# ═══ Redis ═══
REDIS_URL=redis://redis:6379

# ═══ Neon City Simulation ═══
GRID_WIDTH=80
GRID_HEIGHT=80
TICK_INTERVAL_SECONDS=1.0
TOTAL_TICKS=10000
SEED=42

# ═══ API ═══
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# ═══ Factory API ═══
FACTORY_API_PORT=8080
ENABLE_METRICS=true
ENABLE_CRON=true

# ═══ Security ═══
SECRET_KEY=change...n
# ═══ GitHub ═══
GITHUB_TOKEN=ghp_yo...n
# ═══ Docker ═══
COMPOSE_PROJECT_NAME=ai-factory
