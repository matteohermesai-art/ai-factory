# .env.example - AI Factory Configuration
# Copy to .env and customize

# Application
APP_NAME=ai-factory
APP_ENV=development
LOG_LEVEL=info

# Database (production: PostgreSQL)
DATABASE_URL=postgresql+asyncpg://neon:neon@db:5432/neoncity
# Database (development: SQLite)
# DATABASE_URL=sqlite+aiosqlite:///ai-factory.db

# Redis
REDIS_URL=redis://redis:6379

# API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Workers
MAX_WORKERS=5
ENABLE_CRON=true
DELEGATION_TIMEOUT=300

# Security
SECRET_KEY=generate-a-64-char-random-secret

# GitHub (optional)
GITHUB_TOKEN=ghp_your...token

# Docker
COMPOSE_PROJECT_NAME=ai-factory
